# Configuration non secrète. Copier vers .env.gcp à la racine du dépôt.
GCP_PROJECT_ID=devpod-gpu-exploration
GCP_REGION=europe-west4
GCP_ZONE=europe-west4-a
GCP_INSTANCE_NAME=frangi-blackwell-spot
GCP_MAX_RUN_DURATION=8h
GCP_GUEST_SHUTDOWN_MINUTES=240
GCP_NETWORK_INTERFACE=network=default,nic-type=GVNIC
GCP_RUNTIME_SERVICE_ACCOUNT=

